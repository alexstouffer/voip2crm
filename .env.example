# Copy to .env and fill in. config.yaml references these as ${VAR}.
# Real shell exports override these, so this file is just convenient defaults.

# Twenty CRM (self-hosted) — required when crm.provider: twenty
TWENTY_API_KEY=

# Webhook receiver shared token — the provider must call .../webhook?token=THIS
WEBHOOK_TOKEN=

# OpenPhone/Quo — signing secret from the webhook you create (source: webhook)
OPENPHONE_SIGNING_SECRET=

# Twilio — only if webhook.provider: twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# HubSpot — only if crm.provider: hubspot
HUBSPOT_TOKEN=

# WhisperX speaker diarization — only if whisperx.diarize: true
HF_TOKEN=

# LLM-based extraction — only if extract.use_llm: true
ANTHROPIC_API_KEY=
