# Copy to .env and fill in. config.yaml references these as ${VAR}.
# Real shell exports override these, so this file is just convenient defaults.

# Twenty CRM (self-hosted) — required when crm.provider: twenty
TWENTY_API_KEY=

# HubSpot — only if you switch crm.provider: hubspot
HUBSPOT_TOKEN=

# WhisperX speaker diarization — only if whisperx.diarize: true
HF_TOKEN=

# LLM-based extraction — only if extract.use_llm: true
ANTHROPIC_API_KEY=
